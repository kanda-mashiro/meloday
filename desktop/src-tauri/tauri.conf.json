{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyTodo Capture",
  "version": "0.1.0",
  "identifier": "cc.kanda-mashiro.mytodo.capture",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5182",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Capture",
        "width": 640,
        "height": 72,
        "minWidth": 640,
        "minHeight": 72,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
